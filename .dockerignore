# =============================================================================
# StackSentry — Docker Context Exclusions
# =============================================================================
# Keeps build context small by excluding dev/unnecessary files
# =============================================================================

# Dependencies (installed inside container)
node_modules/
**/node_modules/
__pycache__/
**/__pycache__/
*.pyc
.venv/
venv/

# Build outputs
.next/
**/.next/
out/
build/
dist/

# Environment files
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Testing
coverage/
.vitest/

# Docker volumes
pgdata/
redisdata/

# Logs
*.log
logs/

# Misc
*.tsbuildinfo
.vercel/
.github/
.git/
.gitignore
README.md
docs/

# Backend tests (not needed in production image)
backend/tests/
backend/migrations/
