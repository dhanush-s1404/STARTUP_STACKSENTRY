# =============================================================================
# StackSentry Technologies — Environment Variables
# =============================================================================
# Copy this file to .env.local (frontend) or .env (backend) and fill in values.
# Never commit .env files to version control.
# =============================================================================

# ── Frontend (Next.js) ──────────────────────────────────────────────────────

# API base URL (used by browser/client)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Application URL (used for canonical URLs, OG tags, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Analytics ID (Google Analytics, Plausible, etc.)
NEXT_PUBLIC_ANALYTICS_ID=

# Optional: Log level (debug | info | warn | error)
NEXT_PUBLIC_LOG_LEVEL=info

# ── Backend (FastAPI) ───────────────────────────────────────────────────────

# Database connection (async PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stacksentry

# Redis connection
REDIS_URL=redis://localhost:6379

# JWT signing secret (REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=change-me-in-production

# Access token expiry (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment (development | staging | production)
ENVIRONMENT=development

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# ── Docker Compose ──────────────────────────────────────────────────────────

# PostgreSQL credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stacksentry

# Exposed ports
DB_PORT=5432
REDIS_PORT=6379
