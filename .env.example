# =============================================================================
# StackSentry Technologies — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Frontend (Next.js)
# ─────────────────────────────────────────────────────────────────────────────

# Backend API URL (include /api suffix)
NEXT_PUBLIC_API_URL=https://startup-stacksentry.onrender.com/api

# Your Vercel frontend URL
NEXT_PUBLIC_APP_URL=https://startup-stacksentry-frontend-fqrv.vercel.app

# Optional
NEXT_PUBLIC_ANALYTICS_ID=
NEXT_PUBLIC_LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# Backend (FastAPI)
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (asyncpg driver required)
DATABASE_URL=postgresql+asyncpg://YOUR_USER:YOUR_PASSWORD@YOUR_HOST:6543/YOUR_DB

# Redis
REDIS_URL=redis://localhost:6379

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

ACCESS_TOKEN_EXPIRE_MINUTES=30

ENVIRONMENT=production

# Comma-separated allowed origins (no trailing slash)
CORS_ORIGINS=https://startup-stacksentry-frontend-fqrv.vercel.app

# ─────────────────────────────────────────────────────────────────────────────
# Docker (local development only)
# ─────────────────────────────────────────────────────────────────────────────

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stacksentry

DB_PORT=5432
REDIS_PORT=6379
